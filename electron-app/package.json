{
  "name": "adv-electron",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Mean Estimation & Scientific Calculator",
  "author": "ADV Project",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --linux",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.adv.estimation",
    "productName": "Mathly",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Education"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.38.0",
    "jstat": "^1.9.6",
    "katex": "^0.16.45",
    "lucide-react": "^1.11.0",
    "mathjs": "^15.2.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
